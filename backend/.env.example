# Database connection string
# For local SQLite: sqlite:///./calendly.db
# For production PostgreSQL: postgresql://user:password@host/dbname
# For production MySQL: mysql://user:password@host/dbname
DATABASE_URL=sqlite:///./calendly.db

# CORS Allowed Origins
# Comma-separated list of allowed frontend URLs. Use * for development.
# Example: https://my-calendly-clone.vercel.app,https://www.my-calendly-clone.vercel.app
ALLOWED_ORIGINS=*
